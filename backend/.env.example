# ═══════════════════════════════════════════
# Arizonalex Backend - Environment Variables
# ═══════════════════════════════════════════

# ── Server ──
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ── Database ──
# MongoDB Atlas connection string (REQUIRED for production)
# Get yours at: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/arizonalex?retryWrites=true&w=majority

# ── Authentication ──
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=30d

# ── Google OAuth ──
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ── Agora (Voice/Video Calls) ──
AGORA_APP_ID=your-agora-app-id
AGORA_APP_CERTIFICATE=your-agora-app-certificate

# ── AI (Groq) ──
GROQ_API_KEY=your-groq-api-key

# ── Email (Optional - for production email sending) ──
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# FROM_EMAIL=noreply@arizonalex.com

# ── File Storage (Future - for image/voice uploads) ──
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret
